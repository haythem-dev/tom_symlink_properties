<?xml version="1.0" encoding="Windows-1252"?>
<VisualStudioProject
	ProjectType="Visual C++"
	Version="7.10"
	Name="UnitTest"
	ProjectGUID="{95608456-A1D0-4221-9416-612794D38F45}"
	RootNamespace="UnitTest"
	Keyword="Win32Proj">
	<Platforms>
		<Platform
			Name="Win32"/>
	</Platforms>
	<Configurations>
		<Configuration
			Name="Debug|Win32"
			OutputDirectory="$(ConfigurationName)"
			IntermediateDirectory="$(ConfigurationName)"
			ConfigurationType="1"
			CharacterSet="2"
			WholeProgramOptimization="FALSE">
			<Tool
				Name="VCCLCompilerTool"
				Optimization="0"
				AdditionalIncludeDirectories="&quot;$(MARATHON_CSC_BATCHES)\ext\unittest++\include&quot;;&quot;$(MARATHON_CSC_BATCHES)\ext\libutil\include&quot;;&quot;$(MARATHON_CSC_BATCHES)\ext\ssuk\basar\include&quot;;&quot;$(MARATHON_CSC_BATCHES)\ext\ssuk\log4cplus\include&quot;;&quot;$(MARATHON_CSC_BATCHES)\ext\ssuk\boost&quot;;&quot;$(QTDIR)/include&quot;;&quot;$(QTDIR)\include\QtCore&quot;;&quot;$(MARATHON_CSC_BATCHES)\src\CSC_Batches_History&quot;;&quot;$(MARATHON_CSC_BATCHES)\src\CSC_Batches_OrderProposal&quot;;&quot;$(SolutionDir)..\..\ext\libutil\include&quot;"
				PreprocessorDefinitions="WIN32;_DEBUG;_CONSOLE; UNITTESST2_TOBECHANGED"
				MinimalRebuild="TRUE"
				BasicRuntimeChecks="3"
				RuntimeLibrary="3"
				UsePrecompiledHeader="3"
				PrecompiledHeaderThrough="cmnut.h"
				PrecompiledHeaderFile="$(IntDir)/cmnut.pch"
				WarningLevel="4"
				WarnAsError="TRUE"
				SuppressStartupBanner="FALSE"
				Detect64BitPortabilityProblems="TRUE"
				DebugInformationFormat="3"/>
			<Tool
				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLinkerTool"
				AdditionalOptions="/WX
"
				AdditionalDependencies="libbasarcmnutil.lib libbasardbsql.lib libbasardbaspect.lib libbasarproperty.lib libbasarlogin.lib libbasarappl.lib libbasarguitie.lib libbasarguiqt.lib libbasarqtwidget.lib liblog4cplus.lib unittest++.lib QtCored4.lib libutil.lib"
				OutputFile="$(OutDir)/CSCUnitTest.exe"
				LinkIncremental="2"
				SuppressStartupBanner="TRUE"
				AdditionalLibraryDirectories="&quot;$(MARATHON_CSC_BATCHES)\ext\unittest++\lib\$(ConfigurationName)&quot;;&quot;$(MARATHON_CSC_BATCHES)\ext\ssuk\basar\lib\$(ConfigurationName)&quot;;&quot;$(MARATHON_CSC_BATCHES)\ext\ssuk\log4cplus\lib\$(ConfigurationName)&quot;;&quot;$(QTDIR)\lib&quot;;&quot;$(MARATHON_CSC_BATCHES)\ext\ssuk\boost\lib&quot;;&quot;$(MARATHON_CSC_BATCHES)\ext\libutil\lib\$(ConfigurationName)&quot;;&quot;$(MARATHON_CSC_BATCHES)\src\CSC_Batches_OrderProposal\$(ConfigurationName)&quot;;&quot;$(MARATHON_CSC_BATCHES)\src\CSC_Batches_History\$(ConfigurationName)&quot;"
				IgnoreDefaultLibraryNames=""
				GenerateDebugInformation="TRUE"
				ProgramDatabaseFile="$(OutDir)/$(TargetName).pdb"
				SubSystem="1"
				OptimizeReferences="1"
				TargetMachine="1"/>
			<Tool
				Name="VCMIDLTool"/>
			<Tool
				Name="VCPostBuildEventTool"
				Description="start unittest $(ConfigurationName)"/>
			<Tool
				Name="VCPreBuildEventTool"/>
			<Tool
				Name="VCPreLinkEventTool"/>
			<Tool
				Name="VCResourceCompilerTool"/>
			<Tool
				Name="VCWebServiceProxyGeneratorTool"/>
			<Tool
				Name="VCXMLDataGeneratorTool"/>
			<Tool
				Name="VCWebDeploymentTool"/>
			<Tool
				Name="VCManagedWrapperGeneratorTool"/>
			<Tool
				Name="VCAuxiliaryManagedWrapperGeneratorTool"/>
		</Configuration>
		<Configuration
			Name="Release|Win32"
			OutputDirectory="$(ConfigurationName)"
			IntermediateDirectory="$(ConfigurationName)"
			ConfigurationType="1"
			CharacterSet="2">
			<Tool
				Name="VCCLCompilerTool"
				Optimization="4"
				EnableIntrinsicFunctions="TRUE"
				FavorSizeOrSpeed="1"
				OmitFramePointers="TRUE"
				OptimizeForWindowsApplication="TRUE"
				AdditionalIncludeDirectories="&quot;$(MARATHON_CSC_BATCHES)\src\CSC_Batches_History&quot;;&quot;$(MARATHON_CSC_BATCHES)\ext\unittest++\include&quot;;&quot;$(MARATHON_CSC_BATCHES)\src\libutil&quot;;&quot;$(MARATHON_CSC_BATCHES)\ext\ssuk\basar\include&quot;;&quot;$(MARATHON_CSC_BATCHES)\ext\ssuk\log4cplus\include&quot;;&quot;$(MARATHON_CSC_BATCHES)\ext\ssuk\boost&quot;;&quot;$(QTDIR)/include&quot;;&quot;$(QTDIR)\include\QtCore&quot;"
				PreprocessorDefinitions="WIN32;NDEBUG;_CONSOLE"
				StringPooling="TRUE"
				RuntimeLibrary="2"
				BufferSecurityCheck="FALSE"
				UsePrecompiledHeader="3"
				PrecompiledHeaderThrough="cmnut.h"
				PrecompiledHeaderFile="$(IntDir)/cmnut.pch"
				WarningLevel="4"
				WarnAsError="TRUE"
				Detect64BitPortabilityProblems="TRUE"/>
			<Tool
				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLinkerTool"
				AdditionalOptions="/WX
"
				AdditionalDependencies="libbasarcmnutil.lib libbasardbsql.lib libbasardbaspect.lib libbasarproperty.lib libbasarlogin.lib libbasarappl.lib libbasarguitie.lib libbasarguiqt.lib libbasarqtwidget.lib liblog4cplus.lib unittest++.lib QtCore4.lib"
				OutputFile="$(OutDir)/CSCUnitTest.exe"
				LinkIncremental="1"
				SuppressStartupBanner="TRUE"
				AdditionalLibraryDirectories="&quot;$(MARATHON_CSC_BATCHES)\src\irm\$(ConfigurationName)&quot;;&quot;$(MARATHON_CSC_BATCHES)\src\libirm\$(ConfigurationName)&quot;;&quot;$(MARATHON_CSC_BATCHES)\ext\unittest++\lib\$(ConfigurationName)&quot;;&quot;$(MARATHON_CSC_BATCHES)\ext\ssuk\basar\lib\$(ConfigurationName)&quot;;&quot;$(MARATHON_CSC_BATCHES)\ext\ssuk\log4cplus\lib\$(ConfigurationName)&quot;;&quot;$(QTDIR)\lib&quot;"
				SubSystem="1"
				TargetMachine="1"/>
			<Tool
				Name="VCMIDLTool"/>
			<Tool
				Name="VCPostBuildEventTool"
				Description="start unittest $(ConfigurationName)"
				CommandLine="if not defined CISERVER start /b /d$(MARATHON_CSC_BATCHES)\ext\ssuk\sharedlib\release $(TargetPath)"/>
			<Tool
				Name="VCPreBuildEventTool"/>
			<Tool
				Name="VCPreLinkEventTool"/>
			<Tool
				Name="VCResourceCompilerTool"/>
			<Tool
				Name="VCWebServiceProxyGeneratorTool"/>
			<Tool
				Name="VCXMLDataGeneratorTool"/>
			<Tool
				Name="VCWebDeploymentTool"/>
			<Tool
				Name="VCManagedWrapperGeneratorTool"/>
			<Tool
				Name="VCAuxiliaryManagedWrapperGeneratorTool"/>
		</Configuration>
	</Configurations>
