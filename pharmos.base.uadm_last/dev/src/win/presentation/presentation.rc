/////////////////////////////////////////////////////////////////////////////
//
// Icon
//

// Icon with lowest ID value placed first to ensure application icon
// remains consistent on all systems.
IDR_MAINFRAME           ICON                    "icon1.ico"


/////////////////////////////////////////////////////////////////////////////
//
// Toolbar
//

IDR_MAINFRAME TOOLBAR 16, 15
BEGIN
    BUTTON      ID_FILE_NEW
    BUTTON      ID_FILE_OPEN
    BUTTON      ID_FILE_SAVE
    SEPARATOR
    BUTTON      ID_EDIT_CUT
    BUTTON      ID_EDIT_COPY
    BUTTON      ID_EDIT_PASTE
    SEPARATOR
    BUTTON      ID_FILE_PRINT
    BUTTON      ID_APP_ABOUT
END


/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU
BEGIN
    POPUP "&Datei"
    BEGIN
        MENUITEM "Host-&Wechsel zu pps2",       ID_CHANGE_HOST
        MENUITEM SEPARATOR
        MENUITEM "&Beenden",                    ID_APP_EXIT
    END
    POPUP "Benutzer-&Verwaltung"
    BEGIN
        MENUITEM "B&enutzer pflegen...",        ID_ADM_USER
        MENUITEM "Benutzer-&Gruppen...",        ID_ADM_GROUP
        MENUITEM SEPARATOR
        POPUP "&Rechte vergeben"
        BEGIN
            MENUITEM "&User-Rechte...",             ID_ADM_USER_RIGHTS
            MENUITEM "Gru&ppen-Rechte...",          ID_ADM_GROUP_RIGHTS
        END
        POPUP "E&xpress"
        BEGIN
            MENUITEM "&User-Rechte...",             ID_EXP_USR_RIGHTS
            MENUITEM "&Gruppen-Rechte...",          ID_EXPRESS_GRP_RIGHTS
            MENUITEM "&Profil übernehmen...",       ID_EXPRESS_ANALOG
            MENUITEM "Benutzer-Gruppen-&Zuordnung...", ID_EXPRESS_COR_USER
        END
        MENUITEM SEPARATOR
        MENUITEM "Rechte zu User...",           ID_BENUTZER_RECHTE
        MENUITEM "User zu Recht...",            ID_ANALYSE_USER
        MENUITEM SEPARATOR
        MENUITEM "Benutzergruppen-Rechte…",     ID_ANALYSE_USERRIGHTS
        MENUITEM "Benutzer &Manager...",        ID_USER_MANAGER
    END
    POPUP "&Login-Dialog"
    BEGIN
        POPUP "DB &konfigurieren"
        BEGIN
            MENUITEM "Applikation / Module / Rec&hte...", ID_DBKONFIGURIEREN_APPLIKATION
            MENUITEM "&Filialen / Regionen...",     ID_DBKONFIGURIEREN_FILIALEN
            MENUITEM "&Sprachen...",                ID_DBKONFIGURIEREN_TEXTE
            MENUITEM "Benut&zergruppen...",         ID_DBKONFIGURIEREN_GRUPPEN
            MENUITEM "Benutzertypen...",            ID_DBCONFIG_USERTYPES
            MENUITEM "Benutzerparameter...",        ID_DBCONFIG_USERPARAMS
            MENUITEM "Applikationsp&arameter...",   ID_DBCONFIG_APPPARAMS
            MENUITEM SEPARATOR
            MENUITEM "&Texte...",                   ID_DBKONFIGURIEREN_LABEL
            MENUITEM SEPARATOR
            MENUITEM "Vorble&ndungen für Anwender...", ID_DBKONFIGURIEREN_PREVIOUSLOGIN
        END
        MENUITEM SEPARATOR
        MENUITEM "Doku zu libs&cmlogin",        ID_DLL_DOKU
    END
    POPUP "&?"
    BEGIN
        MENUITEM "D&oku zu UsrAdmin",           ID_INFO_DOKU
        MENUITEM "&Info über UsrAdmin...",      ID_INFO_ABOUT
    END
END


