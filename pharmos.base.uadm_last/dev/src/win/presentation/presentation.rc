    EDITTEXT        IDC_EDT_FILTER_USERNAME,48,18,54,12,ES_AUTOHSCROLL
    EDITTEXT        IDC_EDT_FILTER_SURNAME,108,18,48,12,ES_AUTOHSCROLL
    EDITTEXT        IDC_EDT_FILTER_FORENAME,162,18,48,12,ES_AUTOHSCROLL
    EDITTEXT        IDC_EDT_FILTER_USERTYPE,216,18,54,12,ES_AUTOHSCROLL
    EDITTEXT        IDC_EDT_FILTER_COUNTRY,276,18,24,12,ES_AUTOHSCROLL
