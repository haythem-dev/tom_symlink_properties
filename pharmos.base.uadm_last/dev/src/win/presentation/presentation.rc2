#ifndef _MAC
/////////////////////////////////////////////////////////////////////////////
//
// Version
//

#include "uadm_version.h"


VS_VERSION_INFO VERSIONINFO
 FILEVERSION C_VERSION_MAJORNR, C_VERSION_MINORNR, C_VERSION_BUILDNR, C_VERSION_RESERVED
 PRODUCTVERSION C_VERSION_MAJORNR, C_VERSION_MINORNR, C_VERSION_BUILDNR, C_VERSION_RESERVED
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x4L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040704e4"
        BEGIN
            VALUE "CompanyName", C_COMPANYNAME
            VALUE "FileDescription", C_FILEDESCRIPTION
            VALUE "FileVersion", C_VERSION_STRING
            VALUE "InternalName", C_FILE_NAME
            VALUE "Copyright (C) 2004", C_COMPANYNAME
            VALUE "OriginalFilename", C_FILE_NAME
            VALUE "ProductName", C_PRODUCT_NAME
            VALUE "LibVersion", C_LIBVERSION_STRING
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x407, 1252
    END
END

#endif    // !_MAC


