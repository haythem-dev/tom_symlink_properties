@using Resources

@model UadmWebLoginService.Models.LoginViewModel

@{
    Layout = null;
    ViewBag.Title = @Resources.TitleLogin;
}

<!-- Add Bootstrap CSS -->
<link href="~/Content/bootstrap.min.css" rel="stylesheet" type="text/css" />
<script src="~/Scripts/jquery-3.7.1.min.js" type="text/javascript"></script>
<link href="~/Content/login.css" rel="stylesheet" type="text/css" />

<div class="background">
    <div class="login-container mx-auto my-5 shadow-lg">
        <h2 class="mb-4 font-weight-bold text-primary">@Resources.TitleLogin</h2>
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

            <div class="form-group row align-items-center">
                @if (Model.HideApplications == false)
                {
                    <label class="col-sm-4 col-form-label font-weight-bold text-left" for="SelectedApplication">@Resources.LabelApplication</label>
                    <div class="col-sm-8">
                        @if (Model.DisableApplications == false)
                        {
                            @Html.DropDownListFor(m => m.SelectedApplication, new SelectList(Model.Applications, "Key", "Value"), "Select an option", new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.SelectedApplication, "", new { @class = "text-danger" })
                        }
                        else
                        {
                            @Html.DropDownListFor(m => m.SelectedApplication, new SelectList(Model.Applications, "Key", "Value"), "Select an option", new { @class = "form-control", disabled = "disabled" })
                            <input type="hidden" name="SelectedApplication" value="@Model.SelectedApplication" />
                            <input type="hidden" name="DisableApplications" value="true" />
                        }
                    </div>
                }
                else
                {
                    <input type="hidden" name="SelectedApplication" value="@Model.SelectedApplication" />
                    <input type="hidden" name="HideApplications" value="true" />
                }
            </div>

            <div class="form-group row align-items-center">
                <label class="col-sm-4 col-form-label font-weight-bold text-left" for="Username">@Resources.LabelUsername</label>
                <div class="col-sm-8">
                    @Html.EditorFor(model => model.Username, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.Username, null, new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group row align-items-center">
                <label class="col-sm-4 col-form-label font-weight-bold text-left" for="Password">@Resources.LabelPassword</label>
                <div class="col-sm-8">
                    <input type="password" class="form-control" id="Password" name="Password" value="@(Model.Password ?? "")" />
                    @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="form-group row align-items-center">
                @if (Model.HideEnvironments == false)
                {
                    <label class="col-sm-4 col-form-label font-weight-bold text-left" for="SelectedEnvironment">@Resources.LabelEnvironment</label>
                    <div class="col-sm-8">
                        @if (Model.DisableEnvironments == false)
                        {
                            @Html.DropDownListFor(m => m.SelectedEnvironment, new SelectList(Model.Environments, "Key", "Value"), "Select an option", new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.SelectedEnvironment, "", new { @class = "text-danger" })
                        }
                        else
                        {
                            @Html.DropDownListFor(m => m.SelectedEnvironment, new SelectList(Model.Environments, "Key", "Value"), "Select an option", new { @class = "form-control", disabled = "disabled" })
                            <input type="hidden" name="SelectedEnvironment" value="@Model.SelectedEnvironment" />
                            <input type="hidden" name="DisableEnvironments" value="true" />
                        }
                    </div>
                }
                else
                {
                    <input type="hidden" name="SelectedEnvironment" value="@Model.SelectedEnvironment" />
                    <input type="hidden" name="HideEnvironments" value="true" />
                }
            </div>

            <div class="form-group row align-items-center">
                @if (Model.HideCountries == false)
                {
                    <label class="col-sm-4 col-form-label font-weight-bold text-left" for="SelectedCountry">@Resources.LabelCountry</label>
                    <div class="col-sm-8">
                        @Html.DropDownListFor(m => m.SelectedCountry, new SelectList(Model.Countries, "Key", "Value"), "Select an option", new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.SelectedCountry, "", new { @class = "text-danger" })
                    </div>
                }
                else
                {
                    <input type="hidden" name="HideCountries" value="true" />
                }
            </div>

            <div class="form-group row align-items-center">
                @if (Model.HideApplicationItems == false)
                {
                    <label class="col-sm-4 col-form-label font-weight-bold text-left" for="SelectedApplicationItem">@Resources.LabelRegionOrBranch</label>
                    <div class="col-sm-8">
                        @Html.DropDownListFor(m => m.SelectedApplicationItem, new SelectList(Model.ApplicationItems, "Key", "Value"), "Select an option", new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.SelectedApplicationItem, "", new { @class = "text-danger" })
                    </div>
                }
                else
                {
                    <input type="hidden" name="HideApplicationItems" value="true" />
                }
            </div>

            <div class="form-group row align-items-center">
                @if (Model.HideLanguages == false)
                {
                    <label class="col-sm-4 col-form-label font-weight-bold text-left" for="SelectedLanguage">@Resources.LabelLanguage</label>
                    <div class="col-sm-8">
                        @Html.DropDownListFor(m => m.SelectedLanguage, new SelectList(Model.Languages, "Key", "Value"), "Select an option", new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.SelectedLanguage, "", new { @class = "text-danger" })
                    </div>
                }
                else
                {
                    <input type="hidden" name="HideLanguages" value="true" />
                }
            </div>

            <input type="hidden" name="OriginUrl" value="@Model.OriginUrl" />
            <input type="hidden" name="OsAccount" value="@Model.OsAccount" />

            <button type="submit" class="btn btn-primary btn-block mt-4" formaction="@Url.Action("Index", "Login")">Login</button>
            
            <div class="form-group row align-items-center">
                @if (Model.ShowPasswordChangeButton == true)
                {
                    <div class="col-sm-12 text-center">
                        @using (Html.BeginForm("ChangePassword", "Login", FormMethod.Post))
                        {
                            <button type="submit" class="btn btn-link" formaction="@Url.Action("ChangePassword", "Login")">@Resources.LabelChangePassword</button>
                        }
                    </div>
                }
            </div>
         }
    </div>
</div>

<script type="text/javascript">
    $(function () {
        $('form').on('submit', function () {
            var $form = $(this);

            // Set all input fields and select dropdowns as readonly or disabled
            $form.find('input, select').each(function () {
                var $field = $(this);

                // For input fields, set readonly
                if ($field.is('input')) {
                    $field.prop('readonly', true);
                }

                // For select dropdowns, disable them
                if ($field.is('select')) {
                    $field.prop('readonly', true);
                }
            });

            // Disable the submit button
            $form.find('button[type="submit"]').prop('disabled', true);
        });

        // Other event handlers (e.g., for dropdown changes)...
    });

    $(function () {
        $('#SelectedApplication').change(function () {
            var selectedValue = $(this).val();

            $.ajax({
                url: '@Url.Action("GetEnvironmentsForApplication", "Login")',
                type: 'POST',
                data: { applicationKey: selectedValue },
                success: function (data) {
                    var $env = $('#SelectedEnvironment');
                    $env.empty();
                    $env.append($('<option>').val('').text('Select an option'));
                    $.each(data, function (i, item) {
                        $env.append($('<option>').val(item.Key).text(item.Value));
                    });

                    var $items = $('#SelectedCountry');
                    $items.empty();

                    var $items = $('#SelectedApplicationItem');
                    $items.empty();
                },
                error: function () {
                    alert('Error loading environments.');
                }
            });
        });

        $('#SelectedEnvironment').change(function () {
            var selectedValue = $(this).val();
            var selectedApplication = $('#SelectedApplication').val(); // Get the current application

            $.ajax({
                url: '@Url.Action("GetApplicationCountries", "Login")',
                type: 'POST',
                data: {
                    applicationKey: selectedApplication,
                    environmentKey: selectedValue
                },
                success: function (data) {
                    var $env = $('#SelectedCountry');
                    $env.empty();
                    $env.append($('<option>').val('').text('Select an option'));
                    $.each(data, function (i, item) {
                        $env.append($('<option>').val(item.Key).text(item.Value));
                    });

                    var $items = $('#SelectedApplicationItem');
                    $items.empty();
                },
                error: function () {
                    alert('Error loading application countries.');
                }
            });
        });

        $('#SelectedCountry').change(function () {
            var selectedValue = $(this).val();
            var selectedApplication = $('#SelectedApplication').val(); // Get the current application
            var selectedEnvironment = $('#SelectedEnvironment').val(); // Get the current environment

            $.ajax({
                url: '@Url.Action("GetApplicationItems", "Login")',
                type: 'POST',
                data: {
                    applicationKey: selectedApplication,
                    environmentKey: selectedEnvironment,
                    countryKey: selectedValue
                },
                success: function (data) {
                    var $env = $('#SelectedApplicationItem');
                    $env.empty();
                    $env.append($('<option>').val('').text('Select an option'));
                    $.each(data, function (i, item) {
                        $env.append($('<option>').val(item.Key).text(item.Value));
                    });
                },
                error: function () {
                    alert('Error loading application items.');
                }
            });
        });

        $('#SelectedLanguage').change(function () {
            var selectedLang = $(this).val();
            var $form = $(this).closest('form');
            $form.attr('action', '@Url.Action("ChangeLanguage", "Login")'); // Set to your endpoint
            $form.submit();
        });
    });
</script>